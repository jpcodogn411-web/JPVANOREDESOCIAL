rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper to check if user is the resource owner
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper to check if the caller is the fixed super admin
    function isAdmin() {
      return isAuth() && (
        request.auth.token.email == 'jpvanoredesocial@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // General match all fallback to allow super admin total bypass
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      // Allow user themselves to update bio/photo, or admin to modify (admin is already caught by the global catch-all)
      allow update: if isOwner(userId);
    }

    // Posts collection rules
    match /posts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // Allow author to update/delete, or admin (caught by global match)
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;

      // Subcollection for comments
      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      }
    }

    // Chats and messaging rules
    match /chats/{chatId} {
      allow read: if isAuth() && (request.auth.uid in resource.data.participantIds);
      // Allow creating chat if caller is one of the participantIds
      allow create: if isAuth() && (request.auth.uid in request.resource.data.participantIds);
      allow update: if isAuth() && (request.auth.uid in resource.data.participantIds);

      match /messages/{messageId} {
        allow read: if isAuth() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds);
        allow create: if isAuth() && request.resource.data.senderId == request.auth.uid && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds);
      }
    }

    // Follow documents rules
    match /follows/{followId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.followerId == request.auth.uid;
    }

    // Notification document rules
    match /notifications/{notificationId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
