{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile inside JPvano",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "followersCount": { "type": "number" },
        "followingCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "username", "displayName"]
    },
    "Post": {
      "title": "Post",
      "description": "Post sharing text, image, or vertical TikTok-style reel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "userUsername": { "type": "string" },
        "userPhotoURL": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video", "none"] },
        "likes": { "type": "array" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "hashtags": { "type": "array" },
        "isReel": { "type": "boolean" },
        "viewsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "content", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Reply left on a specific global post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "userUsername": { "type": "string" },
        "userPhotoURL": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "content", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Private conversation room between two users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participantIds": { "type": "array" },
        "lastMessage": { "type": "string" },
        "lastMessageSenderId": { "type": "string" },
        "lastMessageTime": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participantIds"]
    },
    "Message": {
      "title": "Message",
      "description": "Individual message inside a private Chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderUsername": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "content", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "description": "Follow link from one user to another",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "followerId", "followingId"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Real-time notification list for an active user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderUsername": { "type": "string" },
        "senderPhotoURL": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow", "message"] },
        "postId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "senderId", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents indexed by their authentication uid"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Global user posts and shorts reels info"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Post comments list"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Meta info about direct message chat room"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Stream of chat transcripts"
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "Main follow index mapper with ID: followerId_followingId"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "List of alerts and social updates for users"
    }
  }
}
